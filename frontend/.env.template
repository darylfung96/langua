# Backend API URL — use http:// for local development, https:// for production
# Example: VITE_BACKEND_URL=https://yourdomain.com
VITE_BACKEND_URL=http://localhost:8000

VITE_TRANSCRIBE_API_KEY=

# OPTIONAL — Set to "true" to use Google Cloud TTS (WaveNet voices) on the shadowing page.
# Requires GOOGLE_CLOUD_TTS_API_KEY to be set in the backend .env as well.
# When false or unset, the browser's built-in speech synthesis is used instead.
VITE_GOOGLE_TTS_ENABLED=false
