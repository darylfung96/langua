# ──────────────────────────────────────────────
# Language Learner Backend — Environment Template
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# REQUIRED — Secret key for signing JWT tokens. Use a long, random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# OPTIONAL — JWT token lifetime in minutes (default: 1440 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth2 — create credentials at https://console.cloud.google.com/
# Set the Authorized redirect URI to: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# OPTIONAL — Gemini session cookies for image generation (legacy web API).
# See Issue #21: migrate to the official Gemini API key when possible.
GEMINI_COOKIE_1PSID=
GEMINI_COOKIE_1PSIDTS=

# REQUIRED for audio generation — Official Gemini API key.
# Create one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OPTIONAL — Override the Whisper model (default: medium).
# Valid values: tiny, base, small, medium, large
WHISPER_MODEL_NAME=medium

# OPTIONAL — Database URL (default: SQLite at ./stories.db).
# For production use a real database, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/language_learner
DATABASE_URL=

# OPTIONAL — Comma-separated list of allowed CORS origins (default: http://localhost:5173).
# Example for production: CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:5173

# OPTIONAL — Host the API server binds to (default: 127.0.0.1).
# Set to 0.0.0.0 to listen on all interfaces in a container/cloud environment.
API_HOST=127.0.0.1

# OPTIONAL — Directory for temporary files during image processing (default: system temp dir).
# TEMP_DIR=/tmp

# OPTIONAL — Logging configuration (default: INFO, development).
# LOG_LEVEL=DEBUG|INFO|WARNING|ERROR|CRITICAL
# LOG_FORMAT=development|json  (development = human-readable, json = structured logs)
# LOG_LEVEL=INFO
# LOG_FORMAT=development

# OPTIONAL — Enable SQL query logging (default: false). Useful for debugging.
# SQL_ECHO=true|false
# SQL_ECHO=false

# OPTIONAL — Timeout for audio transcription in seconds (default: 300 = 5 minutes).
# TRANSCRIBE_TIMEOUT=300

