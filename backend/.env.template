# ──────────────────────────────────────────────
# Language Learner Backend — Environment Template
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# REQUIRED — Secret key for signing JWT tokens. Use a long, random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# OPTIONAL — JWT token lifetime in minutes (default: 1440 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth2 — create credentials at https://console.cloud.google.com/
# Set the Authorized redirect URI to: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# OPTIONAL — Gemini session cookies for image generation (legacy web API).
# See Issue #21: migrate to the official Gemini API key when possible.
GEMINI_COOKIE_1PSID=
GEMINI_COOKIE_1PSIDTS=

# REQUIRED for audio generation — Official Gemini API key.
# Create one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OPTIONAL — Google Cloud Text-to-Speech API key for high-quality TTS on the shadowing page.
# Free tier: 1M Standard chars/month, 4M WaveNet chars/month.
# Create one at: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Then generate an API key at: https://console.cloud.google.com/apis/credentials
# When not set, the shadowing page falls back to the browser's built-in speech synthesis.
GOOGLE_CLOUD_TTS_API_KEY=

# OPTIONAL — Timeout (seconds) for each Google Cloud TTS API call (default: 30).
# TTS_REQUEST_TIMEOUT=30

# OPTIONAL — Speaking rate for TTS audio (default: 0.9 = slightly slower for language learners).
# Valid range: 0.25–4.0. 1.0 = normal speed.
# TTS_SPEAKING_RATE=0.9

# OPTIONAL — Override the Whisper model (default: medium).
# Valid values: tiny, base, small, medium, large
WHISPER_MODEL_NAME=medium

# OPTIONAL — Database URL (default: SQLite at ./stories.db).
# For production use a real database, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/language_learner
DATABASE_URL=

# OPTIONAL — Directory for uploaded media files (default: ./uploads relative to backend).
# Set an absolute path outside the codebase for production persistence.
# UPLOADS_DIR=/var/data/language_learner/uploads
UPLOADS_DIR=

# OPTIONAL — Auto-initialize database on startup (default: true in development, false in production).
# Set AUTO_INIT_DB=true to run create_all() on startup (convenient for development).
# In production, set to false and use Alembic migrations exclusively.
# AUTO_INIT_DB=true

# OPTIONAL — Comma-separated list of allowed CORS origins (default: http://localhost:5173).
# Example for production: CORS_ORIGINS=https://app.example.com,https://www.example.com
# NOTE: Use only HTTPS origins in production.
CORS_ORIGINS=http://localhost:5173

# OPTIONAL — Explicitly set production mode (default: auto-detected).
# If set to "true", enables production-specific behaviors (HTTPS enforcement, stricter CSRF, etc.).
# You typically don't need to set this - production mode is automatically enabled when:
#   - DATABASE_URL uses a non-SQLite database (e.g., PostgreSQL), OR
#   - You set this variable explicitly.
# PRODUCTION=false

# OPTIONAL — Database connection pool settings (for PostgreSQL/MySQL only; ignored for SQLite).
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=3600
# DB_POOL_TIMEOUT=30

# OPTIONAL — Host the API server binds to (default: 127.0.0.1).
# Set to 0.0.0.0 to listen on all interfaces in a container/cloud environment.
API_HOST=127.0.0.1

# OPTIONAL — Port the API server listens on (default: 8000).
# API_PORT=8000

# OPTIONAL — Directory for temporary files during image processing (default: system temp dir).
# TEMP_DIR=/tmp

# OPTIONAL — Logging configuration (default: INFO, development).
# LOG_LEVEL=DEBUG|INFO|WARNING|ERROR|CRITICAL
# LOG_FORMAT=development|json  (development = human-readable, json = structured logs)
# LOG_LEVEL=INFO
# LOG_FORMAT=development

# OPTIONAL — Enable SQL query logging (default: false). Useful for debugging.
# SQL_ECHO=true|false
# SQL_ECHO=false

# OPTIONAL — Timeout for audio transcription in seconds (default: 300 = 5 minutes).
# TRANSCRIBE_TIMEOUT=300

# OPTIONAL — Timeout for Gemini AI requests in seconds (default: 180 = 3 minutes).
# AI_REQUEST_TIMEOUT=180

# OPTIONAL — CSRF protection settings
# CSRF_MAX_AGE=604800  # 7 days in seconds (default)
# CSRF_SECRET=  # Optional: HMAC secret for CSRF tokens. If unset, derives from JWT_SECRET_KEY.

# HTTPS/SSL Configuration for the server — paths to SSL certificate and key files for enabling HTTPS
# These are NOT the standard SSL_CERT_FILE/SSL_KEY_FILE to avoid interfering with outbound connections.
# For development with self-signed certs: SERVER_SSL_CERT_FILE=./cert.pem, SERVER_SSL_KEY_FILE=./key.pem
# Leave unset to run HTTP only.
# SERVER_SSL_CERT_FILE=
# SERVER_SSL_KEY_FILE=

# NOTE: Production mode is automatically detected if:
#  1) PRODUCTION=true is set, OR
#  2) DATABASE_URL is not SQLite (e.g., PostgreSQL).
# You can explicitly set PRODUCTION=true to force production behaviour regardless of database.


